<div
  class="flip-card-shell"
  data-flip-card
  data-flipped="false"
  role="button"
  tabindex="0"
  aria-label="Flip profile card to view details"
>
  <div class="flip-card-inner" data-flip-inner>
    <article class="card-face card-front">
      <div class="glare-effect" data-glare></div>

      <div class="card-top-row">
        <div>
          <p class="terminal-mark">JPT</p>
          <p class="mini-label">Portfolio Profile</p>
        </div>
        <p class="year-tag">2026</p>
      </div>

      <div class="photo-wrap">
        <img
          src="/images/profile.jpeg"
          alt="Portrait of Jhan Pauline Tan"
          class="photo-img"
          loading="eager"
          decoding="async"
        />
      </div>

      <div class="card-bottom-row">
        <p>Certified Bookkeeper</p>
        <h3 class="candidate-name">Jhan Pauline Tan</h3>
      </div>
    </article>

    <article class="card-face card-back">
      <div class="glare-effect" data-glare></div>

      <div class="back-logo-block">
        <div class="back-logo-wrap">
          <img
            src="/images/lsu_logo.png"
            alt="La Salle University Ozamiz logo"
            class="back-logo"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <div class="back-school-block">
        <h4 class="back-school-title">La Salle University</h4>
        <p class="back-school-city">Ozamiz City</p>
      </div>

      <div class="back-credential-block">
        <div class="back-credential-main">
          <p class="credential-label">Verified Credential</p>
          <p class="degree-title">
            Bachelor of Science in<br />
            <span>Accounting Information System</span>
          </p>
        </div>

        <div class="back-chip">
          <p>Certified Bookkeeper</p>
        </div>
      </div>
    </article>
  </div>
</div>

<style>
  .flip-card-shell {
    width: min(100%, 390px);
    margin-inline: auto;
    aspect-ratio: 4 / 5;
    position: relative;
    cursor: pointer;
    perspective: 1400px;
    -webkit-perspective: 1400px;
    outline: none;
  }

  .flip-card-shell:focus-visible {
    box-shadow: 0 0 0 3px rgba(255, 7, 88, 0.35);
    border-radius: 24px;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    -webkit-transform-style: preserve-3d;
    transition: transform 520ms cubic-bezier(0.2, 0.9, 0.26, 1.08);
    will-change: transform;
  }

  .card-face {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    padding: 1.15rem;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    overflow: hidden;
    box-shadow: 0 22px 38px rgba(0, 0, 0, 0.18);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .card-front {
    background:
      radial-gradient(circle at 10% 15%, rgba(255, 7, 88, 0.22), transparent 28%),
      linear-gradient(150deg, #191716, #0f0e0e 75%);
    color: #f9f7f7;
    transform: rotateY(0deg) translateZ(1px);
  }

  .card-back {
    background:
      radial-gradient(circle at 90% 10%, rgba(255, 7, 88, 0.2), transparent 30%),
      linear-gradient(170deg, #f6f4f3, #e4dfdc 70%);
    color: #151211;
    transform: rotateY(180deg) translateZ(1px);
    align-items: center;
    justify-content: space-between;
    text-align: center;
    padding: 1.45rem;
  }

  .back-logo-block {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .back-logo-wrap {
    width: clamp(170px, 55%, 245px);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .back-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    mix-blend-mode: multiply;
    filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.12));
  }

  .back-school-block {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .back-school-title {
    margin: 0;
    font-size: clamp(1.08rem, 2vw, 1.28rem);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.05;
    font-weight: 800;
  }

  .back-school-city {
    margin: 0.2rem 0 0;
    font-size: 0.66rem;
    font-weight: 800;
    color: #c70545;
    text-transform: uppercase;
    letter-spacing: 0.22em;
  }

  .back-credential-block {
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .back-credential-main {
    border-top: 1px solid rgba(0, 0, 0, 0.12);
    padding-top: 0.8rem;
    margin-bottom: 0.7rem;
  }

  .credential-label {
    margin: 0 0 0.38rem;
    font-size: 0.58rem;
    font-weight: 700;
    color: #7d7571;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .degree-title {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1.28;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .degree-title span {
    color: #c70545;
  }

  .back-chip {
    display: inline-block;
    background: rgba(255, 7, 88, 0.15);
    padding: 0.35rem 0.72rem;
    border-radius: 999px;
  }

  .back-chip p {
    margin: 0;
    font-size: 0.58rem;
    font-weight: 800;
    color: #8e1138;
    text-transform: uppercase;
    letter-spacing: 0.11em;
  }

  .card-top-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.6rem;
    position: relative;
    z-index: 2;
  }

  .terminal-mark {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: #ff5f8e;
    text-shadow:
      0 0 6px rgba(255, 7, 88, 0.95),
      0 0 14px rgba(255, 7, 88, 0.78),
      0 0 24px rgba(255, 7, 88, 0.58);
    animation: neonPulse 2s ease-in-out infinite alternate;
  }

  @keyframes neonPulse {
    from {
      text-shadow:
        0 0 4px rgba(255, 7, 88, 0.85),
        0 0 10px rgba(255, 7, 88, 0.62),
        0 0 18px rgba(255, 7, 88, 0.45);
    }
    to {
      text-shadow:
        0 0 8px rgba(255, 7, 88, 1),
        0 0 18px rgba(255, 7, 88, 0.86),
        0 0 30px rgba(255, 7, 88, 0.66);
    }
  }

  .mini-label {
    margin: 0.12rem 0 0;
    font-size: 0.63rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    opacity: 0.75;
  }

  .year-tag {
    margin: 0;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    color: #ff8aab;
  }

  .photo-wrap {
    position: relative;
    z-index: 2;
    flex: 1;
    border-radius: 18px;
    overflow: hidden;
    background: #2a2928;
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .card-bottom-row {
    position: relative;
    z-index: 2;
  }

  .candidate-name {
    margin: 0.25rem 0 0;
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    letter-spacing: -0.02em;
  }

  .glare-effect {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at var(--x, 50%) var(--y, 50%),
      rgba(255, 255, 255, 0.23) 0%,
      transparent 60%
    );
    opacity: 0;
    pointer-events: none;
    transition: opacity 240ms ease;
    z-index: 1;
  }

  .flip-card-shell:hover .glare-effect,
  .flip-card-shell:focus-visible .glare-effect {
    opacity: 1;
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('[data-flip-card]');

  cards.forEach((container) => {
    if (container.dataset.bound === 'true') return;
    container.dataset.bound = 'true';

    const inner = container.querySelector('[data-flip-inner]');
    const glares = container.querySelectorAll('[data-glare]');
    let isFlipped = container.dataset.flipped === 'true';

    if (!(inner instanceof HTMLElement)) return;

    const applyTransform = (rotateX: number, rotateY: number, scale: number = 1): void => {
      inner.style.transform = `rotateY(${rotateY}deg) rotateX(${rotateX}deg) scale(${scale})`;
    };

    const resetCard = (duration = '520ms') => {
      inner.style.transitionDuration = duration;
      const baseY = isFlipped ? 180 : 0;
      applyTransform(0, baseY, 1);
    };

    resetCard('0ms');

    container.addEventListener('mousemove', (event) => {
      if (!(event instanceof MouseEvent)) return;

      const rect = container.getBoundingClientRect();
      const x = (event.clientX - rect.left) / rect.width;
      const y = (event.clientY - rect.top) / rect.height;

      const tiltX = (0.5 - y) * 14;
      const tiltY = (x - 0.5) * 18;
      const baseY = isFlipped ? 180 : 0;

      glares.forEach((glare) => {
        if (glare instanceof HTMLElement) {
          glare.style.setProperty('--x', `${x * 100}%`);
          glare.style.setProperty('--y', `${y * 100}%`);
        }
      });

      inner.style.transitionDuration = '180ms';
      applyTransform(tiltX, baseY + tiltY, 1.025);
    });

    container.addEventListener('mouseleave', () => {
      resetCard('520ms');
    });

    const toggleFlip = () => {
      isFlipped = !isFlipped;
      container.dataset.flipped = isFlipped ? 'true' : 'false';
      resetCard('620ms');
    };

    container.addEventListener('click', toggleFlip);

    container.addEventListener('keydown', (event) => {
      if (!(event instanceof KeyboardEvent)) return;
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        toggleFlip();
      }
    });
  });
</script>
