---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import Awards from '../components/Awards.astro';
import Certifications from '../components/Certifications.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout
  title="Jhan Pauline Tan | Certified Bookkeeper Portfolio"
  description="Portfolio of Jhan Pauline Tan, Certified Bookkeeper and Accounting Information System graduate with expertise in QuickBooks, Xero, Excel, and ESL instruction."
>
  <header class="site-header">
    <div class="nav-wrap">
      <nav aria-label="Primary">
        <ul class="nav-list">
          <li><a href="#about">About</a></li>
          <li><a href="#services">Services</a></li>
          <li><a href="#skills">Skills</a></li>
          <li><a href="#experience">Experience</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main id="main-content">
    <Hero />
    <About />
    <Skills />
    <Experience />
    <Education />
    <Awards />
    <Certifications />
    <Contact />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>© {new Date().getFullYear()} Jhan Pauline Tan. All rights reserved.</p>
    </div>
  </footer>
</BaseLayout>
